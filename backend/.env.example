APP_NAME=Distributed Cloud Storage API
DATABASE_URL=postgresql+psycopg://storage_user:replace-with-strong-password@postgres:5432/distributed_storage
UPLOAD_DIR=temp
STORAGE_DIR=storage
CHUNK_COUNT=3
NODE_NAMES=node1,node2,node3
CORS_ALLOWED_ORIGINS=https://api.yourdomain.com
MAX_UPLOAD_SIZE_MB=50
REPLICATION_FACTOR=2
JWT_SECRET_KEY=replace-with-secure-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
API_USERNAME=admin
API_PASSWORD=admin123
ENCRYPTION_KEY=replace-with-secure-key
REDIS_URL=redis://redis:6379/0
ENABLE_NODE_HEALTH_CHECK=true
FORCE_HTTPS_REDIRECT=false
ALLOWED_EXTENSIONS=*
POSTGRES_PASSWORD=replace-with-strong-password
